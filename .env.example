BOT_TOKEN= create a new bot using @botfather and put its token here
TELEGRAPH_ACCESS_TOKEN= use generate_telegraph_access_token.py to get a token and put it here
DATABASE_URL=postgresql://postgres.xxxxxxxxx:YOUR_PASSWORD@SERVERREGION.pooler.supabase.com:5432/postgres
BOT_OWNER_ID= your Telegram user ID (restricts /session debug command)

# --- Webhook configuration ---
WEBHOOK_URL=https://your-app.example.com   # public HTTPS base URL Telegram delivers updates to (required)
PORT=8080                                  # port to bind; PaaS platforms inject this automatically
WEBHOOK_LISTEN=0.0.0.0                      # interface to bind (optional, defaults to 0.0.0.0)
WEBHOOK_PATH=webhook                        # endpoint path appended to WEBHOOK_URL (optional)
WEBHOOK_SECRET_TOKEN=                       # optional shared secret; Telegram echoes it back for verification
